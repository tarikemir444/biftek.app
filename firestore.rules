rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Yardımcı fonksiyonlar
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isAuthor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'author'];
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Koleksiyonu
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Sadece kendi profilini güncelleyebilir, rol değiştiremez (bu admin işi)
      allow update: if isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bio', 'expertise', 'portfolio']);
      allow create: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // Articles (Haberler) Koleksiyonu
    match /articles/{articleId} {
      allow read: if true; // Herkes okuyabilir
      allow create: if isAuthor();
      // Yazarlar sadece kendi yazılarını güncelleyebilir, Admin her şeyi yapabilir
      allow update: if isAdmin() || (isAuthor() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin(); // Sadece Admin silebilir
    }

    // Applications (Başvurular) Koleksiyonu
    match /applications/{appId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin(); // Sadece admin onaylayabilir
      allow delete: if isAdmin();
    }

    // Feedback (Geri Bildirim) Koleksiyonu
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if true; // Misafirler de gönderebilir
      allow update, delete: if isAdmin();
    }

    // Notifications (Bildirimler) Koleksiyonu
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Likes ve Bookmarks (Alt koleksiyonlar veya ayrı yapılar için genel kural)
    match /{document=**}/likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isOwner(resource.data.userId);
    }
    
    match /{document=**}/bookmarks/{bookmarkId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isOwner(resource.data.userId);
    }
  }
}